# AI News Telegram Bot - Environment Variables
# انسخ هذا الملف إلى .env واملأ البيانات الحقيقية
# هذه البيانات يجب أن تُضاف كـ GitHub Secrets في المستودع

# Telegram Bot Token (من @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (معرف المحادثة)
CHAT_ID=your_chat_id_here

# OpenRouter API Key (من openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here
